# Copy to .env.local (gitignored) or use npm scripts: build:tunnel | build:local
#
# --- SSH tunnel to VPS ---
# Terminal 1: ssh -N -L 3001:127.0.0.1:3001 root@YOUR_DROPLET_IP
# Terminal 2: pnpm --filter @workspace/player run build:tunnel && pnpm --filter @workspace/player exec cap sync ios
#
# --- OR local speed-api on this Mac (pnpm --filter @workspace/api-server run dev, PORT=3001) ---
# pnpm --filter @workspace/player run build:local && pnpm --filter @workspace/player exec cap sync ios
#
# iOS Simulator: 127.0.0.1 is always the host Mac.
# VITE_SPEED_API_ORIGIN=https://speed-api.example.com
VITE_SPEED_API_ORIGIN=http://127.0.0.1:3001
